# Copy to terraform.tfvars and fill in. (terraform.tfvars is gitignored — keep secrets out of git.)

aws_region   = "eu-west-1"
github_repo  = "OWNER/MurderMystery"   # exactly as on GitHub, e.g. yannickarmoo/MurderMystery
frontend_url = "https://your-frontend.example.com"

anthropic_api_key = "sk-ant-..."
# hf_token        = ""

# If the GitHub OIDC provider already exists in this AWS account, set:
# create_oidc_provider = false

# --- Frontend (S3 + CloudFront) -------------------------------------------
# Frontend repo for the CI deploy role (S3 upload + CloudFront invalidation):
# frontend_github_repo = "OWNER/Creative-Website-Redesign"

# Custom domain (optional). Leave both empty to use the default CloudFront URL.
# domain_name       = "play.example.com"
# route53_zone_name = "example.com"   # set only if DNS is hosted in Route 53 here
